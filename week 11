from django.shortcuts import render

def home(request):
    return render(request, "menu.html", {"message": "This is Home Page"})

def about(request):
    return render(request, "menu.html", {"message": "This is About Page"})

def services(request):
    return render(request, "menu.html", {"message": "This is Services Page"})

def contact(request):
    return render(request, "menu.html", {"message": "This is Contact Page"})

